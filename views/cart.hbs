<div class="page-container">
  <div class="page-header">
    <a href="/" class="back-link">← Continue Shopping</a>
    <h1 class="page-title">Your Cart</h1>
    {{#if cartCount}}<span class="page-count">{{cartCount}} item{{#if (gt cartCount 1)}}s{{/if}}</span>{{/if}}
  </div>

  {{#if empty}}
  <div class="empty-state">
    <div class="empty-icon">🛒</div>
    <h2 class="empty-title">Your cart is empty</h2>
    <p class="empty-sub">Looks like you haven't added anything yet.</p>
    <a href="/" class="btn-primary">Start Shopping</a>
  </div>
  {{else}}
  <div class="cart-layout">
    <div class="cart-items">
      {{#each lines}}
      <div class="cart-row">
        <img src="{{product.image}}" alt="{{product.name}}" class="cart-img">
        <div class="cart-info">
          <p class="cart-cat">{{product.category}}</p>
          <h3 class="cart-name">{{product.name}}</h3>
          <span class="cart-unit">${{product.price}} each</span>
        </div>
        <div class="cart-actions">
          <form method="POST" action="/cart/update" class="qty-form" id="form-{{product.id}}">
            <input type="hidden" name="productId" value="{{product.id}}">
            <button type="button" class="qty-btn" onclick="changeQty('{{product.id}}', -1)">−</button>
            <input id="qty-{{product.id}}" class="qty-input" type="number"
              name="qty" value="{{qty}}" min="1" max="99"
              onchange="submitQtyForm('{{product.id}}')">
            <button type="button" class="qty-btn" onclick="changeQty('{{product.id}}', 1)">+</button>
          </form>
          <span class="cart-sub">${{subtotal}}</span>
          <form method="POST" action="/cart/remove" style="display:inline">
            <input type="hidden" name="productId" value="{{product.id}}">
            <button type="submit" class="remove-btn" title="Remove">✕</button>
          </form>
        </div>
      </div>
      {{/each}}

      <div class="cart-clear-row">
        <form method="POST" action="/cart/clear">
          <button type="submit" class="btn-ghost">Clear cart</button>
        </form>
      </div>
    </div>

    <aside class="cart-summary">
      <h2 class="summary-title">Order Summary</h2>
      <div class="summary-row"><span>Subtotal</span><span>${{subtotal}}</span></div>
      {{#if couponCode}}
      <div class="summary-row" style="color: #10b981;"><span>Discount ({{discountPercent}}% [{{couponCode}}])</span><span>-${{discountAmount}}</span></div>
      <div class="summary-row"><span>Discounted Subtotal</span><span>${{discountedSubtotal}}</span></div>
      {{/if}}
      <div class="summary-row"><span>Tax (8%)</span><span>${{tax}}</span></div>
      <div class="summary-row summary-total"><span>Total</span><span>${{total}}</span></div>

      <div class="summary-divider" style="margin: 15px 0; border-top: 1px solid #e5e7eb;"></div>

      {{#if couponMessage}}
      <div class="alert alert-success" style="margin: 10px 0; padding: 8px; font-size: 0.9rem; border-radius: 4px; background-color: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0;">{{couponMessage}}</div>
      {{/if}}
      {{#if couponError}}
      <div class="alert alert-error" style="margin: 10px 0; padding: 8px; font-size: 0.9rem; border-radius: 4px; background-color: #fef2f2; color: #991b1b; border: 1px solid #fca5a5;">{{couponError}}</div>
      {{/if}}

      <form method="POST" action="/cart/coupon" class="coupon-form" style="margin: 15px 0 20px 0; display: flex; gap: 8px;">
        <input type="text" name="couponCode" class="form-input" placeholder="Promo code" value="{{#if couponCode}}{{couponCode}}{{/if}}" style="padding: 8px 12px; font-size: 0.9rem; flex-grow: 1; border: 1px solid #d1d5db; border-radius: 4px;">
        <button type="submit" class="btn-primary" style="padding: 8px 16px; font-size: 0.9rem; border-radius: 4px; cursor: pointer; white-space: nowrap;">Apply</button>
      </form>

      <a href="/checkout" class="btn-primary btn-full">Proceed to Checkout →</a>
    </aside>
  </div>
  {{/if}}
</div>

<script>
function changeQty(productId, delta) {
  const input = document.getElementById('qty-' + productId);
  const newVal = Math.max(1, parseInt(input.value || 1) + delta);
  input.value = newVal;
  submitQtyForm(productId);
}
function submitQtyForm(productId) {
  document.getElementById('form-' + productId).submit();
}
</script>
